{
  "name": "@maritaca/worker",
  "version": "1.4.0",
  "description": "BullMQ worker for processing Maritaca notifications",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@appsignal/opentelemetry-instrumentation-bullmq": "^0.8.0",
    "@aws-sdk/client-ses": "^3.1073.0",
    "@aws-sdk/client-sns": "^3.1073.0",
    "@maritaca/core": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/instrumentation-ioredis": "^0.67.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@slack/types": "^2.21.1",
    "@slack/web-api": "^7.17.0",
    "bullmq": "^5.79.2",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.44.0",
    "ioredis": "^5.11.1",
    "@mailchimp/mailchimp_transactional": "^1.0.59",
    "lru-cache": "^11.3.6",
    "resend": "^6.16.0",
    "twilio": "^6.0.2",
    "web-push": "^3.6.7",
    "@opentelemetry/instrumentation-pg": "^0.71.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.9",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}

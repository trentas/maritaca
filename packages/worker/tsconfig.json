{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "paths": {
      "drizzle-orm": ["../core/node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../core/node_modules/drizzle-orm/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/__tests__/**"],
  "references": [
    {
      "path": "../core"
    }
  ]
}

{
  "name": "@maritaca/api",
  "version": "1.3.1",
  "description": "Fastify HTTP API server for Maritaca",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@maritaca/core": "workspace:*",
    "@slack/web-api": "^7.17.0",
    "dotenv": "^17.4.2",
    "fastify": "^4.26.0",
    "@fastify/env": "^4.2.0",
    "@fastify/rate-limit": "^9.1.0",
    "bullmq": "^5.79.1",
    "ioredis": "^5.11.1",
    "bcrypt": "^5.1.1",
    "drizzle-orm": "^0.45.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/resources": "^2.8.0",
    "@fastify/otel": "^0.19.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/instrumentation-ioredis": "^0.67.0",
    "@appsignal/opentelemetry-instrumentation-bullmq": "^0.8.0",
    "@opentelemetry/instrumentation-pg": "^0.71.0",
    "svix": "^1.96.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/bcrypt": "^5.0.2",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  }
}
